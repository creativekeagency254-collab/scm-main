{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "scm-main.vercel.app" }
      ],
      "destination": "https://muchemi222.vercel.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}